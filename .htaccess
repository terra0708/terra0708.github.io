RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.ozturkavukatlikburosu.av.tr/$1 [L,R=301]

# Enforce trailing slash for clean URLs only
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !\.[^./]+$ [NC]
RewriteRule ^(.+[^/])$ /$1/ [R=301,L]

ErrorDocument 404 /404.html

# Canonical roots
RewriteRule ^$ /tr/ [R=301,L]
RewriteRule ^index\.html$ /tr/ [R=301,L]

# Turkish legacy flat URLs
RewriteRule ^hakkimizda\.html$ /tr/hakkimizda/ [R=301,L]
RewriteRule ^hukuki-alanlar\.html$ /tr/hukuki-alanlar/ [R=301,L]
RewriteRule ^sss\.html$ /tr/sss/ [R=301,L]
RewriteRule ^makaleler\.html$ /tr/makaleler/ [R=301,L]
RewriteRule ^iletisim\.html$ /tr/iletisim/ [R=301,L]

# English legacy flat URLs
RewriteRule ^en/index\.html$ /en/ [R=301,L]
RewriteRule ^en/about\.html$ /en/about/ [R=301,L]
RewriteRule ^en/legal-areas\.html$ /en/legal-areas/ [R=301,L]
RewriteRule ^en/faq\.html$ /en/faq/ [R=301,L]
RewriteRule ^en/articles\.html$ /en/articles/ [R=301,L]
RewriteRule ^en/contact\.html$ /en/contact/ [R=301,L]

# 301: legacy article paths -> hukuki silos (SEO)
RewriteRule ^tr/makaleler/(is-hukuku|aile-hukuku|gayrimenkul-hukuku|calisma-hukuku|miras-hukuku)/(.*)$ /tr/hukuki-alanlar/$1/$2 [R=301,L]
RewriteRule ^en/articles/(labor-law|family-law|real-estate-law|employment-law|inheritance-law)/(.*)$ /en/legal-areas/$1/$2 [R=301,L]

# Legacy article detail pages
RewriteCond %{QUERY_STRING} (^|&)id=1(&|$)
RewriteRule ^makale-detay\.html$ /tr/hukuki-alanlar/is-hukuku/is-hukukunda-yeni-duzenlemeler/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=2(&|$)
RewriteRule ^makale-detay\.html$ /tr/hukuki-alanlar/aile-hukuku/aile-hukukunda-velayet-davalari/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=3(&|$)
RewriteRule ^makale-detay\.html$ /tr/hukuki-alanlar/gayrimenkul-hukuku/gayrimenkul-alim-satim-surecleri/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=4(&|$)
RewriteRule ^makale-detay\.html$ /tr/hukuki-alanlar/calisma-hukuku/calisma-hukukunda-sendika-haklari/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=5(&|$)
RewriteRule ^makale-detay\.html$ /tr/hukuki-alanlar/miras-hukuku/miras-hukuku-ve-vasiyetname/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=6(&|$)
RewriteRule ^makale-detay\.html$ /tr/hukuki-alanlar/aile-hukuku/bosanma-surecleri-ve-haklar/? [R=301,L]
RewriteRule ^makale-detay\.html$ /tr/makaleler/ [R=301,L]

RewriteCond %{QUERY_STRING} (^|&)id=1(&|$)
RewriteRule ^en/article-detail\.html$ /en/legal-areas/labor-law/new-regulations-in-labor-law/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=2(&|$)
RewriteRule ^en/article-detail\.html$ /en/legal-areas/family-law/custody-cases-in-family-law/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=3(&|$)
RewriteRule ^en/article-detail\.html$ /en/legal-areas/real-estate-law/real-estate-purchase-sale-processes/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=4(&|$)
RewriteRule ^en/article-detail\.html$ /en/legal-areas/employment-law/union-rights-in-employment-law/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=5(&|$)
RewriteRule ^en/article-detail\.html$ /en/legal-areas/inheritance-law/inheritance-law-and-wills/? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)id=6(&|$)
RewriteRule ^en/article-detail\.html$ /en/legal-areas/family-law/divorce-processes-and-rights/? [R=301,L]
RewriteRule ^en/article-detail\.html$ /en/articles/ [R=301,L]

